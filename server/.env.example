# PAY.JP API キー
# テスト環境: sk_test_xxxxx
# 本番環境: sk_live_xxxxx
PAYJP_SECRET_KEY=sk_test_xxxxx

# サーバーポート
PORT=3000

# サンプル商品の Price ID
PAYJP_SAMPLE_PRICE_ID=price_xxxxx

# Webhook シークレットトークン (PAY.JP 管理画面で設定したもの)
PAYJP_WEBHOOK_SECRET=

# CORS 許可オリジン (カンマ区切り、未設定時は全オリジン許可)
# ALLOWED_ORIGINS=https://example.com,https://app.example.com
